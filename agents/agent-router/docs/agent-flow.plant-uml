@startuml
  title Router Agent (com.shellaia.agent.router) - process()

  start
  :Read prompt from AIATP body;
  if (prompt is empty?) then (yes)
    :emitError "Prompt is required. Usage: process <text>";
    stop
  endif

  :pruneExpiredRoutes();
  :sessionId = context.id;

  if (sticky reset directive?) then (yes)
    :stickyBySession.remove(sessionId);
    if (remaining prompt is blank?) then (yes)
      :completeJson 200 infoEnvelope("Sticky session cleared");
      stop
    else (no)
      :prompt = remainingPrompt;
    endif
  endif

  :opaqueAuthRelay = isOpaqueAuthRelayPrompt(prompt);
  :excludedAgents = {};
  :reroute = true;

  while (reroute?) is (yes)
    :reroute = false;

    :agents = discoverAgents(context)\n(requires routingHints.skillSummary);
    if (agents is empty?) then (yes)
      :completeJson 200 unhandledIntentEnvelope("No routable agent found...");
      stop
    endif

    :sticky = stickyBySession.get(sessionId);

    if (opaqueAuthRelay?) then (yes)
      :decision = decideOpaqueRelayRoute(prompt, sticky, agents, excludedAgents);
    else (no)
      :decision = decideRoute(prompt, sticky, agents, excludedAgents);
    endif

    if (decision.route is blank?) then (yes)
      :emitError "Could not determine target agent.";
      stop
    endif

    :delegatedPrompt = preDispatch(prompt).delegatedPrompt;
    :delegated = delegateToAgent(decision.route, "process", delegatedPrompt);
    if (delegated is null?) then (yes)
      :completeJson 500 failureEnvelope("delegate_failed");
      stop
    endif

    :delegatedJson = extractFirstJsonBlock(delegated.body);

    if (opaqueAuthRelay?) then (yes)
      :stickyBySession.put(sessionId, updateSticky(...));
      if (completeDelegatedPayload OK?) then (yes)
        stop
      else (no)
        :completeJson 500 failureEnvelope("protocol_error");
        stop
      endif
    endif

    if (indicatesFailureSignal(delegatedJson)?) then (yes)
      :excludedAgents.add(decision.route);
      :stickyBySession.remove(sessionId);

      if (excludeAgents(agents, excludedAgents) is empty?) then (yes)
        :completeJson 200 unhandledIntentEnvelope("No available agent can handle this request.");
        stop
      else (no)
        :emitStatus "Rerouting to another agent.";
        :reroute = true;
      endif

    else (no)
      if (delegatedJson missing channels?) then (yes)
        :completeJson 500 failureEnvelope("protocol_error");
        stop
      else (no)
        :stickyBySession.put(sessionId, updateSticky(...));
        :completeDelegatedPayload(...);
        stop
      endif
    endif
  endwhile (no)

  stop
  @endumltra